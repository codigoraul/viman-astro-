---
const base = import.meta.env.BASE_URL;
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import ProductCard from '@/components/ProductCard.astro';
import { getCategories, getProducts, getProductsByCategory } from '@/lib/wordpress';

export async function getStaticPaths() {
  try {
    const categories = await getCategories();
    const allProducts = await getProducts(200);

    const paths = await Promise.all(
      categories.map(async (category) => {
        let products: any[] = [];

        if (category.id && category.id > 0) {
          products = await getProductsByCategory(category.id);
        }

        if (!products.length) {
          products = allProducts.filter((product: any) =>
            (product?.categorias || []).some((cat: any) => cat.slug === category.slug)
          );
        }

        return {
          params: { slug: category.slug },
          props: { category, products },
        };
      })
    );

    console.log(`⚡ Categorías: ${paths.length} rutas generadas`);
    return paths;
  } catch (error) {
    console.error('Error generating category paths:', error);
    return [];
  }
}

const { slug } = Astro.params;
const { category, products } = Astro.props;

const filteredProducts = (products || []).filter((product: any) =>
  (product?.categorias || []).some((cat: any) => cat.slug === category.slug)
);

if (!category) {
  return Astro.redirect(`${base}/productos/`);
}
---

<Layout title={`${category.name} - VIMAN`} description={category.description || `Productos en la categoría ${category.name}`}>
  <Header />

  <main class="min-h-screen">
    <section class="bg-gray-100 py-12">
      <div class="container mx-auto px-4">
        <nav class="mb-4">
          <a href={`${base}/productos/`} class="text-blue-600 hover:text-blue-800">
            ← Volver a productos
          </a>
        </nav>

        <h1 class="text-4xl font-bold text-gray-800 mb-4">{category.name}</h1>
        {category.description && (
          <p class="text-gray-600 text-lg">{category.description}</p>
        )}
        <p class="text-gray-500 mt-2">{filteredProducts.length} producto{filteredProducts.length !== 1 ? 's' : ''}</p>
      </div>
    </section>

    <section class="container mx-auto px-4 py-12">
      {filteredProducts.length === 0 ? (
        <div class="text-center py-12">
          <p class="text-gray-600 text-lg">No hay productos en esta categoría.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {filteredProducts.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>
      )}
    </section>
  </main>

  <Footer />
</Layout>
