---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import TitleBreadcrumb from '@/components/TitleBreadcrumb.astro';
import { getProducts, getCategories, type WPProduct, type WPCategory } from '@/lib/wordpress';
const base = import.meta.env.BASE_URL;

let products: WPProduct[] = [];
let categories: WPCategory[] = [];
try {
  [products, categories] = await Promise.all([getProducts(100), getCategories()]);
} catch (e) {
  console.error('Error cargando productos:', e);
}

const parentCategories = categories.filter((c) => c.parent === 0);
const productsByCat: Record<number, WPProduct[]> = {};
for (const product of products) {
  for (const cat of ((product as any).categorias || [])) {
    if (!productsByCat[cat.id]) productsByCat[cat.id] = [];
    productsByCat[cat.id].push(product);
  }
}
---

<Layout title="VIMAN - Productos" description="Equipos VIMAN: apoyo terrestre, combustible y atmosféricos. Fabricación nacional para operaciones aeroportuarias e industriales.">
  <Header />

  <main class="min-h-screen bg-white">
    <TitleBreadcrumb
      title="Nuestros Productos"
      subtitle="Soluciones especializadas para operaciones en pista e industria"
    />

    <section class="container mx-auto px-4 py-16" style="max-width: 1240px;">
      <div class="product-categories__grid">
        {parentCategories.map((cat) => {
          const catProducts = productsByCat[cat.id] || [];
          const firstProduct = catProducts[0];
          const image = firstProduct?.imagen_url?.full
            || firstProduct?.imagen_url?.medium
            || firstProduct?.images?.[0]?.src
            || base + "/images/productos/" + cat.slug + ".jpg";

          return (
            <a href={base + "/categoria/" + cat.slug + "/"} class="product-card">
              <div class="product-card__image">
                <img src={image} alt={cat.name} loading="lazy" />
              </div>
              <div class="product-card__body">
                <h3>{cat.name}</h3>
                {cat.description && <p>{cat.description}</p>}
                <span>Ver productos →</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  </main>

  <Footer />

  <style>
    .product-categories__grid {
      display: grid;
      gap: 2rem;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      max-width: 1200px;
      margin: 0 auto;
    }
    .product-card {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      text-align: center;
    }
    .product-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 30px 70px rgba(15, 23, 42, 0.12);
    }
    .product-card__image {
      background: #F1F3F8;
      aspect-ratio: 300 / 200;
      overflow: hidden;
    }
    .product-card__image img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }
    .product-card__body {
      padding: 1.5rem 1.25rem 1.75rem;
    }
    .product-card__body h3 {
      font-size: 1.5rem;
      font-weight: 700;
      color: #1E2A5A;
      margin-bottom: 0.5rem;
    }
    .product-card__body p {
      color: #4B5563;
      line-height: 1.55;
      font-size: 0.95rem;
      margin-bottom: 0.75rem;
    }
    .product-card__body span {
      font-weight: 600;
      color: #FB9500;
    }
  </style>
</Layout>
