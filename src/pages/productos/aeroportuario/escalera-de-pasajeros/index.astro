---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import TitleBreadcrumb from '@/components/TitleBreadcrumb.astro';
import { getCategoryBySlug, getProductsByCategory, getProducts } from '@/lib/wordpress';
const base = import.meta.env.BASE_URL;

// Obtener categoría y productos
let products: any[] = [];
let error = null;

try {
  const escaleraCategory = await getCategoryBySlug('escalera-de-pasajeros');

  if (escaleraCategory) {
    products = await getProductsByCategory(escaleraCategory.id);
  } else {
    // Fallback: filtrar por nombre
    const allProducts = await getProducts(100);
    products = allProducts.filter((product: any) => {
      const name = (product.name || product.title?.rendered || '').toLowerCase();
      return (name.includes('escalera') && name.includes('pasajero')) ||
        product.categorias?.some((cat: any) => cat.slug?.includes('escalera'));
    });
  }

  console.log(`⚡ Escalera de pasajeros: ${products.length} productos cargados`);
} catch (e) {
  error = e;
  console.error('Error loading products:', e);
}

// Helper para obtener excerpt limpio
function getCleanExcerpt(product: any): string {
  const raw = product.descripcion_corta || product.short_description || product.excerpt?.rendered || '';
  return raw.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
}
---

<Layout title="VIMAN - Escalera de Pasajeros">
  <Header />
  
  <main class="min-h-screen">
    <TitleBreadcrumb 
      title="Escalera de Pasajeros" 
      subtitle="Soluciones seguras y eficientes para embarque y desembarque"
      backgroundImage={base + "/images/productos/escalera-pasajeros.jpg"}
    />

    <!-- Main Content -->
    <section class="container mx-auto px-4 py-16">
      <!-- Products Grid -->
      {products.length === 0 && (
        <div class="text-center py-12">
          <p class="text-gray-600 text-base">No hay productos disponibles en esta categoría.</p>
        </div>
      )}

      {products.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
          {products.map((product) => (
            <div class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition">
              <a href={base + "/producto/" + product.slug + "/"} class="block overflow-hidden p-8">
                <img src={
                  product.imagen_url?.full || product.imagen_url?.medium ||
                  product.images?.[0]?.src || base + "/images/placeholder.jpg"
                } alt={product.name || product.title?.rendered || 'Producto'} class="w-full h-auto" />
              </a>
              <div class="p-6">
                <a href={base + "/producto/" + product.slug + "/"} class="block">
                  <h3 class="text-xl font-bold text-primary mb-3">{product.name || product.title?.rendered}</h3>
                </a>
                <div class="text-gray-600 text-base mb-4" set:html={
                  getCleanExcerpt(product).replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim().slice(0, 150) + '...'
                }></div>
                <a href={base + "/producto/" + product.slug + "/"} class="inline-block bg-white text-primary border border-gray-300 px-6 py-3 rounded-lg font-semibold hover:bg-gray-50 hover:border-primary transition-all duration-300 shadow-sm hover:shadow-md text-sm w-full text-center">
                  Ver Detalles
                </a>
              </div>
            </div>
          ))}
        </div>
      )}

      <!-- Features Section -->
      <div class="bg-gray-50 p-8 rounded-lg mb-16">
        <h2 class="text-2xl font-bold text-primary mb-8 text-center">Características Principales</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="w-16 h-16 bg-secondary rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="font-semibold text-primary mb-2">Certificación Internacional</h3>
            <p class="text-gray-600 text-sm">Cumplimiento de normas IATA y FAA</p>
          </div>
          
          <div class="text-center">
            <div class="w-16 h-16 bg-secondary rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="font-semibold text-primary mb-2">Mantenimiento Preventivo</h3>
            <p class="text-gray-600 text-sm">Servicio técnico especializado disponible</p>
          </div>
          
          <div class="text-center">
            <div class="w-16 h-16 bg-secondary rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
            <h3 class="font-semibold text-primary mb-2">Diseño Ergonómico</h3>
            <p class="text-gray-600 text-sm">Comodidad y seguridad para pasajeros</p>
          </div>
          
          <div class="text-center">
            <div class="w-16 h-16 bg-secondary rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="font-semibold text-primary mb-2">Alta Eficiencia</h3>
            <p class="text-gray-600 text-sm">Operación rápida y sin interrupciones</p>
          </div>
        </div>
      </div>

      <!-- Contact Section -->
      <div class="bg-[#E4EFFC] p-8 rounded-lg text-center">
        <h4 class="text-2xl font-bold text-primary mb-4">¿Necesita más información?</h4>
        <p class="text-gray-700 text-base mb-6">Contáctenos para conocer más detalles sobre nuestras escaleras de pasajeros y solicitar una cotización personalizada.</p>
        <a 
          href={base + "/contacto/"} 
          class="inline-block bg-secondary text-white px-8 py-4 rounded-lg font-semibold hover:bg-secondary-dark transition text-base"
        >
          Solicitar Información
        </a>
      </div>
    </section>

    <!-- Related Products -->
    <section class="bg-gray-50 py-16">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-primary mb-12 text-center">Otros Productos Aeroportuarios</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
            <div class="overflow-hidden p-8">
              <img src={base + "/images/productos/camiones-servicio.jpg"} alt="Camiones de servicio" class="w-full h-auto" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-primary mb-3">Camiones de servicio</h3>
              <p class="text-gray-600 text-base">
                Fabricamos estanque para distintas aplicaciones, tanto para camiones de combustibles o aljibes como para sistemas de vacío.
              </p>
            </div>
          </div>

          <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
            <div class="overflow-hidden p-8">
              <img src={base + "/images/productos/carros.jpg"} alt="Carros" class="w-full h-auto" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-primary mb-3">Carros</h3>
              <p class="text-gray-600 text-base">
                Carros de transporte aeroportuario diseñados para optimizar las operaciones en tierra.
              </p>
            </div>
          </div>

          <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
            <div class="h-48 bg-gray-200 flex items-center justify-center">
              <span class="text-gray-500">Más productos</span>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-primary mb-3">Otros Equipamientos</h3>
              <p class="text-gray-600 text-base">
                Contamos con una amplia variedad de equipamientos aeroportuarios para satisfacer todas sus necesidades.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <style>
    /* Estilos para títulos azules */
    .text-primary.font-bold {
      font-weight: 600 !important;
    }
    
    .text-3xl {
      font-size: 34px !important;
    }
    
    /* Estilos para títulos de servicios y productos */
    .text-xl.font-bold.text-primary {
      font-size: 1.55rem !important;
    }
    
    .text-[28px].font-bold.text-primary {
      font-size: 1.55rem !important;
    }
  </style>
</Layout>
