---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import TitleBreadcrumb from '@/components/TitleBreadcrumb.astro';

const rawBase = import.meta.env.BASE_URL ?? '/';
const basePath = rawBase === '/' ? '' : rawBase.replace(/\/$/, '');
const actionUrl = `${basePath}/contacto.php`;
---

<Layout title="VIMAN - Contacto">
  <Header />
  
  <main class="min-h-screen">
    <TitleBreadcrumb 
      title="Contacto" 
      subtitle="Estamos aquí para ayudarte"
    />

    <section class="container mx-auto px-4 pt-24 pb-16">
      <div class="flex flex-col lg:flex-row gap-0 items-stretch">

        <!-- Datos de contacto - Caja azul oscuro estilo viman.cl -->
        <div class="lg:w-1/2  rounded-t-lg lg:rounded-t-none lg:rounded-l-lg p-8 lg:p-10 flex flex-col justify-center">
         <div class="containerForm w-[402px] bg-primary py-12 px-8 ml-20">
          <h2 class="text-2xl font-semibold text-white mb-8">Datos de contacto</h2>

          <div class="space-y-6">
            <div>
              <h3 class="text-secondary text-lg font-bold  mb-1">Fono:</h3>
              <p class="text-white text-sm">+56 978882566</p>
            </div>

            <div>
              <h3 class="text-secondary text-lg font-bold mb-1">Email:</h3>
              <p class="text-white text-sm">info@viman.cl</p>
            </div>

            <div>
              <h3 class="text-secondary text-lg font-bold mb-1">Dirección:</h3>
              <p class="text-white text-sm">Aeropuerto 9390, Cerrillos, Santiago. Chile.</p>
            </div>
          </div>
        </div>
      </div>
        <!-- Formulario de contacto -->
        <div class="w-full lg:w-1/2 bg-white rounded-b-lg lg:rounded-b-none lg:rounded-r-lg p-8 lg:p-10 shadow-lg" id="contacto">
          <h2 class="text-3xl font-semibold text-primary mb-8">Formulario de contacto</h2>

          <div id="contact-status" style="display:none;"></div>

          <form id="contactForm" action={actionUrl} method="POST" class="space-y-5">
            <!-- Honeypot anti-spam -->
            <input type="text" name="_gotcha" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none;" tabindex="-1" autocomplete="off" />

            <div>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary transition"
                placeholder="Su nombre"
              />
            </div>
            <div>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary transition"
                placeholder="Su email"
              />
            </div>
            <div>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="w-full px-4 py-3 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary transition"
                placeholder="Fono"
              />
            </div>
            <div>
              <textarea
                id="mensaje"
                name="mensaje"
                rows="5"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary transition resize-none"
                placeholder="Escriba su mensaje"
              ></textarea>
            </div>
            <button
              type="submit"
              id="submitBtn"
              class="bg-secondary text-white py-3 px-8 rounded-full font-semibold hover:bg-secondary-dark transition uppercase tracking-wide text-sm"
            >
              Enviar mensaje
            </button>
          </form>
        </div>
      </div>
    </section>

    <!-- Mapa - a todo el ancho -->
    <section class="w-full">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3326.3645!2d-70.704577!3d-33.50841!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9662c2d6b5e2c3e1%3A0x0!2zVklNQU4gLSBBZXJvcHVlcnRvIDkzOTAgQ2VycmlsbG9z!5e0!3m2!1ses!2scl!4v1699900000000!5m2!1ses!2scl&q=VIMAN+Aeropuerto+9390+Cerrillos+Santiago"
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Ubicación VIMAN - Aeropuerto 9390, Cerrillos, Santiago"
      ></iframe>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .status-message {
    padding: 1rem 1.5rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.5;
  }
  .status-success {
    background: rgba(34, 197, 94, 0.15);
    border: 1px solid rgba(34, 197, 94, 0.3);
    color: #248F4D;
    font-weight: 600;
  }
  .status-error {
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #dc2626;
  }
  .submit-button-loading {
    opacity: 0.7;
    cursor: not-allowed;
  }
  .spinner {
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top: 2px solid white;
    border-radius: 50%;
    animation: spin 1s linear infinite;
    display: inline-block;
    vertical-align: middle;
    margin-left: 8px;
  }
  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('contactForm');
    const submitBtn = document.getElementById('submitBtn');
    const statusEl = document.getElementById('contact-status');

    if (form) {
      form.addEventListener('submit', async function(e) {
        e.preventDefault();

        // Deshabilitar botón y mostrar loading
        submitBtn.disabled = true;
        submitBtn.classList.add('submit-button-loading');
        const originalHTML = submitBtn.innerHTML;
        submitBtn.innerHTML = 'ENVIANDO...<div class="spinner"></div>';

        try {
          const formData = new FormData(form);
          const response = await fetch(form.action, {
            method: 'POST',
            body: formData
          });

          const result = await response.json();

          if (result.success) {
            // Mensaje de éxito estilo Elquicapital
            statusEl.textContent = result.message;
            statusEl.className = 'status-message status-success';
            statusEl.style.display = '';

            // Limpiar formulario
            form.reset();

            // Scroll al mensaje
            statusEl.scrollIntoView({ behavior: 'smooth', block: 'center' });

            // Ocultar mensaje después de 5 segundos
            setTimeout(() => {
              statusEl.style.display = 'none';
            }, 5000);

          } else {
            // Mensaje de error
            statusEl.textContent = result.message;
            statusEl.className = 'status-message status-error';
            statusEl.style.display = '';
            statusEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }

        } catch (error) {
          // Error de conexión
          statusEl.textContent = 'Error de conexión. Por favor intenta nuevamente.';
          statusEl.className = 'status-message status-error';
          statusEl.style.display = '';
        }

        // Restaurar botón
        submitBtn.disabled = false;
        submitBtn.classList.remove('submit-button-loading');
        submitBtn.innerHTML = originalHTML;
      });
    }
  });
</script>

