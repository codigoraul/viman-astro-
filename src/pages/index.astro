---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import ProductCard from '@/components/ProductCard.astro';
import HeroSlider from '@/components/HeroSlider.astro';
import { getProducts, getCategories, type WPProduct, type WPCategory } from '@/lib/wordpress';

let products: WPProduct[] = [];
let categories: WPCategory[] = [];
let error: unknown = null;

try {
  [products, categories] = await Promise.all([
    getProducts(100),
    getCategories(),
  ]);
} catch (e) {
  error = e;
  console.error('Error loading data:', e);
}

// Hero slider - 3 slides estáticos como en viman.cl
const slides = [
  {
    image: '/muestra/images/slider/slider-1.jpg',
    title: 'Equipos Industriales\nCon alta fidelidad',
    description: 'Desarrollamos equipos industriales de alta fidelidad a través de procesos de ingeniería muy bien estructurados y definidos que permiten obtener resultados de alta calidad garantizada.',
    link: '/muestra/productos/',
    buttonText: 'VER PRODUCTOS',
    secondaryLink: '/muestra/contacto/',
    secondaryButtonText: 'CONTÁCTANOS',
    secondaryButtonColor: 'orange',
  },
  {
    image: '/muestra/images/slider/slider-2.jpg',
    title: 'Construimos Equipos\nIndustriales de alta fidelidad',
    description: 'Desarrollamos equipos industriales de alta fidelidad a través de procesos de ingeniería muy bien estructurados y definidos que permiten obtener resultados de alta calidad garantizada.',
    link: '/muestra/productos/',
    buttonText: 'VER PRODUCTOS',
    secondaryLink: '/muestra/contacto/',
    secondaryButtonText: 'CONTÁCTENOS',
    secondaryButtonColor: 'blue',
  },
  {
    image: '/muestra/images/slider/slider-3.jpg',
    title: 'Ingeniería y mecánica\npara equipos aeroportuarios',
    description: 'Desarrollamos equipos industriales de alta fidelidad a través de procesos de ingeniería muy bien estructurados y definidos que permiten obtener resultados de alta calidad garantizada.',
    link: '/muestra/productos/',
    buttonText: 'VER PRODUCTOS',
  },
];

// Categorías padre e hijos
const parentCategories = categories.filter(c => c.parent === 0);
const childCategoriesMap: Record<number, WPCategory[]> = {};
for (const parent of parentCategories) {
  childCategoriesMap[parent.id] = categories.filter(c => c.parent === parent.id);
}
const parentsWithChildren = parentCategories.filter((parent) => (childCategoriesMap[parent.id] || []).length > 0);

// Productos agrupados por categoría para obtener imágenes
const productsByCat: Record<number, WPProduct[]> = {};
for (const product of products) {
  const cats = (product as any).categorias || [];
  for (const cat of cats) {
    if (!productsByCat[cat.id]) productsByCat[cat.id] = [];
    productsByCat[cat.id].push(product);
  }
}

const services = [
  {
    title: 'Maestranza',
    image: '/muestra/images/servicios/maestranza.jpg',
    description: 'Fabricamos estanques para distintas aplicaciones, tanto para camiones de combustibles o aljibes como para sistemas de vacío.',
    link: '/muestra/servicios/maestranza/'
  },
  {
    title: 'Servicio Tecnico',
    image: '/muestra/images/servicios/servicio-tecnico.jpg',
    description: 'Mantención y reparación de camiones, grúas, maquinaria industrial, generadores eléctricos y motores con servicio especializado.',
    link: '/muestra/servicios/servicio-tecnico/'
  },
  {
    title: 'Mantencion Industrial',
    image: '/muestra/images/servicios/mantencion-industrial.jpg',
    description: 'Mantenciones preventivas y correctivas para prolongar la vida útil de sus equipos y minimizar tiempos de inactividad.',
    link: '/muestra/servicios/mantencion-industrial/'
  },
  {
    title: 'Pintura Industrial',
    image: '/muestra/images/servicios/pintura-industrial.jpg',
    description: 'Servicio de pintura para estanques, camiones y maquinaria con acabados profesionales y protección contra la corrosión.',
    link: '/muestra/servicios/servicio-pintura/'
  },
  {
    title: 'Servicios de Inspeccion',
    image: '/muestra/images/servicios/servicio-de-Inspeccion.jpg',
    description: 'Inspección periódica de estanques de combustibles certificada por Norma PC-110 SEC con emisión de reportes técnicos.',
    link: '/muestra/servicios/servicio-tecnico/'
  }
];
---

<Layout title="VIMAN - Inicio">
  <Header />

  <main class="min-h-screen">
    <HeroSlider slides={slides} />

    <section class="bg-[#F3F4F6] py-16">
      <div class="container mx-auto px-4" style="max-width: 1240px;">
        <div class="text-center mb-12">
          <p class="block text-secondary text-[28px] font-semibold">
            Nuestros servicios
          </p>
          <h2 class="block text-primary text-[36px] font-bold">
            Equipos para el sector aeroportuario
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 pb-10">
          {services.slice(0, 3).map((service) => (
            <article class="service-card group">
              <a href={service.link} class="block">
                <div class="service-card__image-wrap">
                  <img
                    src={service.image}
                    alt={service.title}
                    class="service-card__image"
                    loading="lazy"
                  />
                  <div class="service-card__overlay"></div>
                </div>
                <div class="service-card__body">
                  <h3 class="service-card__title">{service.title}</h3>
                  <p class="service-card__desc">{service.description}</p>
                  <span class="service-card__link">Ver más →</span>
                </div>
              </a>
            </article>
          ))}
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:max-w-4xl md:mx-auto">
          {services.slice(3).map((service) => (
            <article class="service-card group">
              <a href={service.link} class="block">
                <div class="service-card__image-wrap">
                  <img
                    src={service.image}
                    alt={service.title}
                    class="service-card__image"
                    loading="lazy"
                  />
                  <div class="service-card__overlay"></div>
                </div>
                <div class="service-card__body">
                  <h3 class="service-card__title">{service.title}</h3>
                  <p class="service-card__desc">{service.description}</p>
                  <span class="service-card__link">Ver más →</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="container mx-auto px-4 py-16" style="max-width: 1240px;">

      {parentsWithChildren.map((parent) => (
        <div class="mb-16">
          <div class="text-center mb-12">
            <p class="block text-secondary text-[28px] font-semibold">
              Nuestros Productos
            </p>
            <h2 class="block text-primary text-[36px] font-bold">
              {parent.name}
            </h2>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {(childCategoriesMap[parent.id] || []).map((subcat) => {
              const catProducts = productsByCat[subcat.id] || [];
              const firstProduct = catProducts[0];
              const image = firstProduct?.imagen_url?.full
                || firstProduct?.imagen_url?.medium
                || firstProduct?.images?.[0]?.src
                || `/muestra/images/productos/${subcat.slug}.jpg`;

              return (
                <a href={`/muestra/categoria/${subcat.slug}/`} class="prod-card">
                  <div class="prod-card__img-wrap">
                    <img src={image} alt={subcat.name} class="prod-card__img" loading="lazy" />
                    <div class="prod-card__img-overlay"></div>
                  </div>
                  <div class="prod-card__body">
                    <h3 class="prod-card__title">{subcat.name}</h3>
                    {subcat.description && (
                      <p class="prod-card__desc">{subcat.description}</p>
                    )}
                    <span class="prod-card__btn">
                      Ver productos
                      <svg class="prod-card__arrow" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                      </svg>
                    </span>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      ))}

    </section>
  </main>

  <Footer />

  <style>
    .text-primary.font-bold { font-weight: 600 !important; }
    .text-[36px] { font-size: 32px !important; }
    .text-secondary.font-semibold { font-weight: 500 !important; }
    .text-[28px] { font-size: 24px !important; }
    .text-xl.font-bold.text-primary { font-size: 1.55rem !important; }
    .text-[28px].font-bold.text-primary { font-size: 1.55rem !important; }

    /* ── Service Cards ── */
    .service-card {
      background: #fff;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
      transition: transform 0.35s ease, box-shadow 0.35s ease;
    }

    .service-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 12px 32px rgba(5, 15, 104, 0.12);
    }

    .service-card__image-wrap {
      position: relative;
      overflow: hidden;
      height: 220px;
    }

    .service-card__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .service-card:hover .service-card__image {
      transform: scale(1.08);
    }

    .service-card__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, transparent 50%, rgba(5, 15, 104, 0.25) 100%);
      opacity: 0;
      transition: opacity 0.35s ease;
    }

    .service-card:hover .service-card__overlay {
      opacity: 1;
    }

    .service-card__body {
      padding: 1.5rem 1.5rem 1.8rem;
      text-align: center;
    }

    .service-card__title {
      font-size: 1.425rem;
      font-weight: 700;
      color: #050F68;
      margin-bottom: 0.6rem;
    }

    .service-card__desc {
      font-size: 1rem;
      line-height: 1.65;
      color: #6b7280;
      margin-bottom: 1rem;
    }

    .service-card__link {
      display: inline-block;
      font-size: 0.85rem;
      font-weight: 600;
      color: #FB9500;
      letter-spacing: 0.02em;
      transition: color 0.3s ease;
    }

    .service-card:hover .service-card__link {
      color: #C97700;
    }

    @media (max-width: 768px) {
      .service-card__image-wrap {
        height: 200px;
      }
    }

    /* ── Product Cards ── */
    .prod-card {
      display: block;
      text-decoration: none;
      background: #fff;
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 2px 16px rgba(0, 0, 0, 0.07);
      transition: transform 0.35s ease, box-shadow 0.35s ease;
    }

    .prod-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 16px 40px rgba(5, 15, 104, 0.13);
    }

    .prod-card__img-wrap {
      position: relative;
      overflow: hidden;
      height: 240px;
      background: #f8f9fa;
    }

    .prod-card__img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      padding: 1.5rem;
      transition: transform 0.5s ease;
    }

    .prod-card:hover .prod-card__img {
      transform: scale(1.06);
    }

    .prod-card__img-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, transparent 60%, rgba(5, 15, 104, 0.08) 100%);
      pointer-events: none;
    }

    .prod-card__body {
      padding: 1.4rem 1.6rem 1.6rem;
      border-top: 1px solid #f0f0f0;
    }

    .prod-card__title {
      font-size: 1.2rem;
      font-weight: 700;
      color: #050F68;
      margin-bottom: 0.5rem;
    }

    .prod-card__desc {
      font-size: 0.88rem;
      color: #6b7280;
      line-height: 1.55;
      margin-bottom: 1rem;
    }

    .prod-card__btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.95rem;
      font-weight: 600;
      color: #FB9500;
      transition: gap 0.25s ease, color 0.25s ease;
    }

    .prod-card:hover .prod-card__btn {
      gap: 0.7rem;
      color: #C97700;
    }

    .prod-card__arrow {
      width: 16px;
      height: 16px;
      transition: transform 0.25s ease;
    }

    .prod-card:hover .prod-card__arrow {
      transform: translateX(3px);
    }
  </style>
</Layout>
