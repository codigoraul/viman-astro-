---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import TitleBreadcrumb from '@/components/TitleBreadcrumb.astro';
---

<Layout title="VIMAN - Servicio Técnico">
  <Header />

  <main class="min-h-screen bg-white">
    <TitleBreadcrumb
      title="Servicio Técnico"
      subtitle="Respuestas rápidas para mantener tu operación en marcha"
    />

    <section class="container mx-auto px-4 py-16">
      <!-- Mecánica Industrial -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center bg-white rounded-2xl p-10 mb-16">
        <div class="order-2 lg:order-1">
          <div class="rounded-xl overflow-hidden">
            <img
              src="/muestra/images/servicios/mantencion/mantenimiento-correctivo.jpg"
              alt="Mecánica industrial"
              class="w-full h-full object-cover"
            />
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <span class="uppercase tracking-[0.25em] text-sm text-secondary mb-4 block">Especialidad</span>
          <h2 class="text-3xl lg:text-[34px] font-bold text-primary mb-6">Mecánica Industrial</h2>
          <p class="text-lg leading-relaxed text-gray-700 mb-6">
            Disponemos de gran capacidad para la solución en áreas de mecánica, hidráulica, electromecánica y estructural de la maquinaria para cubrir un amplio espectro del servicio.
          </p>
          <ul class="space-y-2 text-gray-700 mb-8 list-disc ml-5">
            <li>Realizamos reparación de carrocerías de camiones.</li>
            <li>Reparación de plumas hidráulicas.</li>
            <li>Mecánica de camiones pesados.</li>
            <li>Servicio de frenos para camiones.</li>
            <li>Reparación de dirección hidráulica.</li>
            <li>Reparación de sistemas eléctricos.</li>
            <li>Reparación de sistemas de aire.</li>
            <li>Reparación de sistemas hidráulicos.</li>
            <li>Repuestos e insumos para maquinaria.</li>
          </ul>
          <a
            href="/muestra/contacto/"
            class="inline-flex items-center justify-center bg-secondary text-white font-semibold px-6 py-3 rounded-lg w-max hover:bg-secondary-dark transition"
          >
            Consultar por servicio
          </a>
        </div>
      </div>

      <!-- Servicio técnico en terreno -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
        <div class="order-1">
          <span class="uppercase tracking-[0.25em] text-sm text-secondary mb-4">En terreno</span>
          <h2 class="text-3xl font-bold text-primary mb-6">Servicios Técnico en terreno</h2>
          <p class="text-gray-700 text-base leading-relaxed mb-4">
            Ofrecemos una amplia gama de soluciones para optimizar el correcto funcionamiento de sus maquinarias y dejarlas operativas lo antes posible en caso de fallas.
          </p>
          <ul class="space-y-2 text-gray-700 list-disc ml-5 mb-6">
            <li>Inspección de máquinas y verificación de funcionamiento.</li>
            <li>Diseño y desarrollo de soluciones para distintas aplicaciones en terreno.</li>
            <li>Suministro de repuestos en terreno.</li>
            <li>Cambio de componentes críticos.</li>
            <li>Pruebas de eficiencia.</li>
            <li>Pruebas de hermeticidad.</li>
            <li>Diseño y fabricaciones de partes y piezas especiales.</li>
          </ul>
          <p class="text-gray-600 italic mb-6">Servicio de maestranza.</p>
          <a
            href="/muestra/contacto/"
            class="inline-flex items-center justify-center bg-secondary text-white font-semibold px-6 py-3 rounded-lg w-max hover:bg-secondary-dark transition"
          >
            Solicitar una visita
          </a>
        </div>
        <div class="order-2">
          <div class="rounded-lg overflow-hidden p-8 bg-gray-50">
            <img
              src="/muestra/images/servicios/servicio-tecnico.jpg"
              alt="Servicio técnico en terreno"
              class="w-full"
            />
          </div>
        </div>
      </div>

      <!-- Servicio de inspección técnica -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center bg-white rounded-2xl p-10">
        <div class="order-1">
          <div class="rounded-xl overflow-hidden">
            <img
              src="/muestra/images/servicios/servicio-de-Inspeccion.jpg"
              alt="Servicio de inspección técnica"
              class="w-full h-full object-cover"
            />
          </div>
        </div>
        <div class="order-2">
          <span class="uppercase tracking-[0.25em] text-sm text-secondary mb-4 block">Control</span>
          <h2 class="text-3xl lg:text-[34px] font-bold text-primary mb-6">Servicio de inspección técnica</h2>
          <p class="text-lg leading-relaxed text-gray-700 mb-6">
            Realizamos Overhaul y levantamiento de mantenimiento integral a generadores de energía.
          </p>
          <ul class="space-y-2 text-gray-700 list-disc ml-5">
            <li>Inspección preliminar.</li>
            <li>Mantención eléctrica.</li>
            <li>Mantención mecánica.</li>
            <li>Análisis de componentes.</li>
            <li>Informe técnico.</li>
          </ul>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
