---
const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="bg-[#000040] text-white mt-[80px]">
  <div class="container mx-auto px-4 py-8 pt-[52px]">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <img 
          src={base + "/images/logo-viman-blanco.png"} 
          alt="VIMAN" 
          class="h-10 w-auto mb-4"
        />
        <p class="text-[#7a92a8] leading-relaxed">
          Fabricamos equipos de apoyo terrestre para el sector aeroportuario con alta calidad de servicio para aprovisionamiento abordo, escaleras de pasajeros, carretas de equipaje, suministro de agua potable y suministro de combustible.
        </p>
      </div>
      
      <div>
        <h4 class="text-xl font-semibold mb-6 mt-4 text-[#c4d0de]">Nuestros Productos</h4>
        <ul class="space-y-2 text-[#7a92a8] mb-8">
          <li>
            <a href={base + "/productos/aeroportuario/"} class="hover:text-orange-500 transition">
              Aeroportuario
            </a>
          </li>
          <li>
            <a href={base + "/productos/combustible/"} class="hover:text-orange-500 transition">
              Combustible
            </a>
          </li>
        </ul>

        <h4 class="text-xl font-semibold mb-6 mt-6 text-[#c4d0de]">Nuestros Servicios</h4>
        <ul class="space-y-2 text-[#7a92a8]">
          <li>
            <a href={base + "/servicios/maestranza-industrial/"} class="hover:text-orange-500 transition">
              Maestranza Industrial
            </a>
          </li>
          <li>
            <a href={base + "/servicios/mantencion-industrial/"} class="hover:text-orange-500 transition">
              Mantención Industrial
            </a>
          </li>
          <li>
            <a href={base + "/servicios/servicio-tecnico/"} class="hover:text-orange-500 transition">
              Servicio Técnico
            </a>
          </li>
          <li>
            <a href={base + "/servicios/servicio-pintura/"} class="hover:text-orange-500 transition">
              Servicio de Pintura
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="text-xl font-semibold mb-4 mt-4 text-[#c4d0de]">Dato de contacto</h4>
        <div class="text-[#7a92a8] leading-loose space-y-2">
          <div class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-orange-500" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"></path>
            </svg>
            <span>+56 978882566</span>
          </div>
          <div class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-orange-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
            </svg>
            <span>Aeropuerto 9390, Cerrillos, Santiago. Chile.</span>
          </div>
          <div class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-orange-500" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
              <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
            </svg>
            <span>info@viman.cl</span>
          </div>
        </div>
      </div>
    </div>
    
    <div class="border-t border-gray-700 mt-8 pt-8 text-center text-[#526070]">
      <p>&copy; {currentYear} VIMAN por <a href="https://diseñopaginas.cl" target="_blank" rel="noopener noreferrer">diseñopaginas.cl</a></p>
    </div>
  </div>
</footer>
