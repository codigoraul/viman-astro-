---
// Header component - menú de navegación principal
const base = import.meta.env.BASE_URL;
---

<header class="header-wrapper">
  <!-- Top Header -->
  <div class="top-header hidden md:block">
    <div class="container mx-auto px-5">
      <div class="flex items-center justify-between py-2 text-sm">
        <div class="flex items-center gap-6 text-white">
          <a href="tel:+56978882566" class="flex items-center gap-2 hover:text-secondary transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <span>+56 97 8882 566</span>
          </a>
          <a href="mailto:info@viman.cl" class="flex items-center gap-2 hover:text-secondary transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <span>info@viman.cl</span>
          </a>
        </div>
        <div class="flex items-center gap-4 text-white">
          <a href="#" class="hover:text-secondary transition">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="#" class="hover:text-secondary transition">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Header -->
  <div class="main-header">
    <nav class="container mx-auto px-4 py-6">
      <div class="flex items-center justify-between">
        <a href={base + "/"} class="logo">
          <img
            src={base + "/images/logo-viman.png"}
            alt="VIMAN"
            class="logo-img logo-color"
          />
          <img
            src={base + "/images/logo-viman-blanco.png"}
            alt="VIMAN"
            class="logo-img logo-white"
          />
        </a>
        
        <div class="flex items-center space-x-8">
          <ul class="hidden lg:flex items-center space-x-8">
            <li>
              <a href={base + "/"} class="nav-link">
                Inicio
              </a>
            </li>
            <li>
              <a href={base + "/nosotros/"} class="nav-link">
                Nosotros
              </a>
            </li>
            <li class="relative group">
              <a href={base + "/servicios/"} class="nav-link flex items-center gap-1">
                Servicios
                <svg class="w-4 h-4 group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </a>
              <div class="absolute top-full left-0 bg-white shadow-lg rounded-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 min-w-[200px] z-50 mt-4">
                <a href={base + "/servicios/maestranza/"} class="block px-4 py-3 text-gray-700 hover:bg-gray-100 hover:text-primary transition">
                  Maestranza
                </a>
                <a href={base + "/servicios/mantencion-industrial/"} class="block px-4 py-3 text-gray-700 hover:bg-gray-100 hover:text-primary transition">
                  Mantención Industrial
                </a>
                <a href={base + "/servicios/servicio-tecnico/"} class="block px-4 py-3 text-gray-700 hover:bg-gray-100 hover:text-primary transition">
                  Servicio Técnico
                </a>
                <a href={base + "/servicios/servicio-pintura/"} class="block px-4 py-3 text-gray-700 hover:bg-gray-100 hover:text-primary transition">
                  Servicio de Pintura
                </a>
              </div>
            </li>
            <li class="relative group">
              <a href={base + "/productos/"} class="nav-link flex items-center gap-1">
                Productos
                <svg class="w-4 h-4 group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </a>
              <div class="absolute top-full left-0 bg-white shadow-lg rounded-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 min-w-[220px] z-50 mt-4 dropdown-panel">
                <div class="dropdown-section">
                  <a href={base + "/productos/aeroportuario/"} class="dropdown-trigger">
                    Productos Aeroportuarios
                    <span class="dropdown-arrow">▸</span>
                  </a>
                  <div class="dropdown-items">
                    <a href={base + "/categoria/escalera-de-pasajeros/"} class="dropdown-item">
                      Escalera de pasajeros
                    </a>
                    <a href={base + "/categoria/camiones-de-servicio/"} class="dropdown-item">
                      Camiones de servicio
                    </a>
                    <a href={base + "/categoria/carro/"} class="dropdown-item">
                      Carro
                    </a>
                  </div>
                </div>
                <div class="dropdown-section">
                  <a href={base + "/productos/combustible/"} class="dropdown-trigger">
                    Productos Combustible
                    <span class="dropdown-arrow">▸</span>
                  </a>
                  <div class="dropdown-items">
                    <a href={base + "/categoria/camiones-combustible/"} class="dropdown-item">
                      Camiones combustible
                    </a>
                    <a href={base + "/categoria/estanque-subterraneo/"} class="dropdown-item">
                      Estanque combustible subterráneo
                    </a>
                    <a href={base + "/categoria/estanque-superficie/"} class="dropdown-item">
                      Estanque combustible superficie
                    </a>
                  </div>
                </div>
              </div>
            </li>
            <li>
              <a href={base + "/contacto/"} class="nav-link">
                Contacto
              </a>
            </li>
          </ul>

          <button class="mobile-menu-btn lg:hidden" id="mobile-menu-btn" aria-label="Abrir menú" aria-expanded="false">
            <svg class="w-6 h-6 menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg class="w-6 h-6 close-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="mobile-menu lg:hidden hidden">
      <div class="container mx-auto px-4 py-3">
        <ul class="space-y-2">
          <li>
            <a href={base + "/"} class="mobile-nav-link block py-2 px-4 text-base font-medium text-gray-800 hover:bg-gray-100 rounded-lg transition">
              Inicio
            </a>
          </li>
          <li>
            <a href={base + "/nosotros/"} class="mobile-nav-link block py-2 px-4 text-base font-medium text-gray-800 hover:bg-gray-100 rounded-lg transition">
              Nosotros
            </a>
          </li>
          <li>
            <div class="mobile-submenu">
              <a href={base + "/servicios/"} class="mobile-nav-link block py-2 px-4 text-base font-medium text-gray-800 hover:bg-gray-100 rounded-lg transition">
                Servicios
              </a>
              <div class="ml-4 mt-1 space-y-1">
                <a href={base + "/servicios/maestranza/"} class="block py-2 px-4 text-base text-gray-600 hover:bg-gray-50 hover:text-primary rounded-lg transition">
                  Maestranza
                </a>
                <a href={base + "/servicios/mantencion-industrial/"} class="block py-2 px-4 text-base text-gray-600 hover:bg-gray-50 hover:text-primary rounded-lg transition">
                  Mantención Industrial
                </a>
                <a href={base + "/servicios/servicio-tecnico/"} class="block py-2 px-4 text-base text-gray-600 hover:bg-gray-50 hover:text-primary rounded-lg transition">
                  Servicio Técnico
                </a>
                <a href={base + "/servicios/servicio-pintura/"} class="block py-2 px-4 text-base text-gray-600 hover:bg-gray-50 hover:text-primary rounded-lg transition">
                  Servicio de Pintura
                </a>
              </div>
            </div>
          </li>
          <li>
            <div class="mobile-submenu">
              <a href={base + "/productos/"} class="mobile-nav-link block py-2 px-4 text-base font-medium text-gray-800 hover:bg-gray-100 rounded-lg transition">
                Productos
              </a>
              <div class="ml-4 mt-1 space-y-1">
                <div>
                  <a href={base + "/productos/combustible/"} class="block py-2 px-4 text-base text-gray-600 hover:bg-gray-50 hover:text-primary rounded-lg transition whitespace-nowrap font-medium">
                    Productos Combustible
                  </a>
                  <div class="ml-4 border-l border-gray-200 space-y-1 mt-1">
                    <a href={base + "/categoria/camiones-combustible/"} class="block py-1 px-4 text-base text-gray-600 hover:bg-gray-50 hover:text-primary rounded-lg transition">
                      Camiones combustible
                    </a>
                    <a href={base + "/categoria/estanque-subterraneo/"} class="block py-1 px-4 text-base text-gray-600 hover:bg-gray-50 hover:text-primary rounded-lg transition">
                      Estanque combustible subterráneo
                    </a>
                    <a href={base + "/categoria/estanque-superficie/"} class="block py-1 px-4 text-base text-gray-600 hover:bg-gray-50 hover:text-primary rounded-lg transition">
                      Estanque combustible superficie
                    </a>
                  </div>
                </div>
                <div>
                  <a href={base + "/productos/aeroportuario/"} class="block py-2 px-4 text-base text-gray-600 hover:bg-gray-50 hover:text-primary rounded-lg transition whitespace-nowrap font-medium">
                    Productos Aeroportuarios
                  </a>
                  <div class="ml-4 border-l border-gray-200 space-y-1 mt-1">
                    <a href={base + "/categoria/escalera-de-pasajeros/"} class="block py-1 px-4 text-base text-gray-600 hover:bg-gray-50 hover:text-primary rounded-lg transition">
                      Escalera de pasajeros
                    </a>
                    <a href={base + "/categoria/camiones-de-servicio/"} class="block py-1 px-4 text-base text-gray-600 hover:bg-gray-50 hover:text-primary rounded-lg transition">
                      Camiones de servicio
                    </a>
                    <a href={base + "/categoria/carro/"} class="block py-1 px-4 text-base text-gray-600 hover:bg-gray-50 hover:text-primary rounded-lg transition">
                      Carro
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </li>
          <li>
            <a href={base + "/contacto/"} class="mobile-nav-link block py-2 px-4 text-base font-medium text-gray-800 hover:bg-gray-100 rounded-lg transition">
              Contacto
            </a>
          </li>
        </ul>
      </div>
    </div>
</header>

<style>
  .header-wrapper {
    position: sticky;
    top: 0;
    z-index: 50;
    background: white;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: background 0.35s ease, box-shadow 0.35s ease;
  }

  /* ── Top header con transición de altura ── */
  .top-header {
    background-color: #050F68;
    border-bottom: 2px solid #FB9500;
    overflow: hidden;
    max-height: 60px;
    transition: max-height 0.35s ease, opacity 0.3s ease, padding 0.3s ease;
    opacity: 1;
  }

  .main-header {
    background-color: white;
    transition: background-color 0.35s ease;
  }

  /* ── Logos ── */
  .logo {
    position: relative;
    display: inline-block;
  }

  .logo-white {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .logo-color {
    opacity: 1;
    transition: opacity 0.35s ease;
  }

  /* ── Nav links ── */
  .nav-link {
    position: relative;
    color: #374151;
    font-weight: 500;
    font-size: 1rem;
    transition: color 0.3s ease;
    padding: 0.5rem 0;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: #FB9500;
    transition: width 0.3s ease;
  }

  .nav-link:hover {
    color: #FB9500;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .mobile-menu-btn {
    color: #050F68;
    transition: color 0.3s ease;
  }

  .mobile-menu-btn:hover {
    color: #FB9500;
  }

  /* ── Estado scrolled ── */
  .header-wrapper.scrolled {
    background: white;
    box-shadow: 0 4px 20px rgba(5, 15, 104, 0.15);
  }

  .header-wrapper.scrolled .top-header {
    max-height: 0;
    opacity: 0;
    padding-top: 0;
    padding-bottom: 0;
    border-bottom: none;
  }

  .header-wrapper.scrolled .main-header {
    background-color: #050F68;
  }

  .header-wrapper.scrolled .logo-color {
    opacity: 0;
  }

  .header-wrapper.scrolled .logo-white {
    opacity: 1;
  }

  .header-wrapper.scrolled .nav-link {
    color: rgba(255, 255, 255, 0.85);
  }

  .header-wrapper.scrolled .nav-link:hover {
    color: #FB9500;
  }

  .header-wrapper.scrolled .mobile-menu-btn {
    color: white;
  }

  /* Flecha del dropdown también en blanco */
  .header-wrapper.scrolled .nav-link svg {
    stroke: rgba(255, 255, 255, 0.85);
  }

  /* ── Mobile menu en estado scrolled ── */
  .header-wrapper.scrolled .mobile-menu {
    background-color: #050F68;
  }

  .header-wrapper.scrolled .mobile-menu a {
    color: rgba(255, 255, 255, 0.80) !important;
  }

  .header-wrapper.scrolled .mobile-menu a:hover {
    color: #FB9500 !important;
    background-color: rgba(255, 255, 255, 0.07) !important;
  }

  .header-wrapper.scrolled .mobile-menu .border-l {
    border-color: rgba(255, 255, 255, 0.15) !important;
  }

  .mobile-nav-link {
    border-bottom: 1px solid #e5e7eb;
  }

  .header-wrapper.scrolled .mobile-nav-link {
    border-bottom-color: rgba(255, 255, 255, 0.1);
  }

  .mobile-nav-link:last-child {
    border-bottom: none;
  }

  .dropdown-panel {
    width: 280px;
  }
  .dropdown-section {
    border-bottom: 1px solid #f3f4f6;
    padding: 0.85rem 1.25rem 0.35rem;
  }
  .dropdown-section:last-child {
    border-bottom: none;
  }
  .dropdown-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding-bottom: 0.4rem;
    color: #374151;
    font-weight: 600;
  }
  .dropdown-trigger:hover {
    color: #FB9500;
  }
  .dropdown-arrow {
    font-size: 0.7rem;
    color: inherit;
  }
  .dropdown-items {
    display: none;
    margin-top: 0.5rem;
    padding-bottom: 0.75rem;
  }
  .dropdown-item {
    display: block;
    padding-left: 0.85rem;
    border-left: 1px solid #e5e7eb;
    color: #6B7280;
    font-size: 0.9rem;
    padding-top: 0.25rem;
    padding-bottom: 0.25rem;
    white-space: nowrap;
  }
  .dropdown-item:hover {
    color: #FB9500;
  }
  .dropdown-section:hover .dropdown-items {
    display: block;
  }

  /* Logo responsive sizes */
  .logo-img {
    width: auto;
    height: 2.6em;
  }
  
  @media (max-width: 767px) {
    .logo-img {
      height: 2em;
    }
  }

  @media (max-width: 1024px) {
    .top-header {
      font-size: 0.875rem;
    }
  }

  @media (max-width: 640px) {
    .top-header .flex {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }

  /* Estilos para títulos de productos y servicios */
  .font-bold {
    font-weight: 600;
  }
  
  .text-[36px] {
    font-size: 34px;
  }
</style>

<script is:inline>
  // Scroll effect - cambia header al hacer scroll
  (function() {
    const header = document.querySelector('.header-wrapper');
    if (!header) return;

    function onScroll() {
      if (window.scrollY > 10) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll(); // estado inicial
  })();

  // Mobile menu toggle - runs immediately
  (function() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    
    if (!btn || !menu) return;
    
    const menuIcon = btn.querySelector('.menu-icon');
    const closeIcon = btn.querySelector('.close-icon');
    
    function toggleMenu() {
      const isHidden = menu.classList.contains('hidden');
      
      if (isHidden) {
        menu.classList.remove('hidden');
        btn.setAttribute('aria-expanded', 'true');
        if (menuIcon) menuIcon.classList.add('hidden');
        if (closeIcon) closeIcon.classList.remove('hidden');
      } else {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        if (menuIcon) menuIcon.classList.remove('hidden');
        if (closeIcon) closeIcon.classList.add('hidden');
      }
    }
    
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      toggleMenu();
    });
    
    // Close when clicking links
    menu.querySelectorAll('a').forEach(function(link) {
      link.addEventListener('click', function() {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        if (menuIcon) menuIcon.classList.remove('hidden');
        if (closeIcon) closeIcon.classList.add('hidden');
      });
    });
    
    // Close when clicking outside
    document.addEventListener('click', function(e) {
      if (!menu.contains(e.target) && !btn.contains(e.target)) {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        if (menuIcon) menuIcon.classList.remove('hidden');
        if (closeIcon) closeIcon.classList.add('hidden');
      }
    });
  })();
</script>
